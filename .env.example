# Copy to .env and fill in your credentials — direnv loads it automatically
# (via `dotenv_if_exists .env` in .envrc). Without direnv:
#   set -a; source .env; set +a

# Spotify app (https://developer.spotify.com/dashboard)
# Register http://127.0.0.1:8080/api/auth/callback as a redirect URI.
AUX_SPOTIFY_CLIENT_ID=
AUX_SPOTIFY_CLIENT_SECRET=

# Anthropic API key (https://platform.claude.com/)
AUX_ANTHROPIC_API_KEY=

# Admin password protecting the app and its settings UI. Leave empty only
# for local development, or when using OIDC below — without either the app
# runs unprotected.
AUX_ADMIN_PASSWORD=

# Optional OpenID Connect single sign-on (e.g. Keycloak). Set the issuer URL
# and client ID to enable an "Sign in with SSO" button. The redirect URI to
# register in the provider is <AUX_PUBLIC_URL>/api/admin/oidc/callback.
#AUX_OIDC_ISSUER_URL=https://keycloak.example.com/realms/aux
#AUX_OIDC_CLIENT_ID=aux
#AUX_OIDC_CLIENT_SECRET=
#AUX_OIDC_SCOPES=openid profile email
# Optional comma-separated allowlist of verified emails permitted to log in:
#AUX_OIDC_ALLOWED_EMAILS=you@example.com

# Optional overrides (defaults shown)
#AUX_ADDR=:8080
#AUX_PUBLIC_URL=http://127.0.0.1:8080
#AUX_ANTHROPIC_MODEL=claude-opus-4-8
#AUX_ANTHROPIC_MAX_TOKENS=8192
#AUX_TOKEN_FILE=spotify-token.json
#AUX_SETTINGS_FILE=aux-settings.json
#AUX_CHATS_DIR=chats
#AUX_STATIC_DIR=frontend/dist
